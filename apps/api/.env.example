# Flask environment
FLASK_ENV=development

# Origin allowed to call this API from the browser (the Next.js `web` app)
CORS_ORIGIN=http://localhost:3000

# Required: Anthropic API key for chat responses (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# RAG: search the SWPS repository on demand. Set to false to turn it off
# (plain chatbot, no repository tool). Accepts: true/false/1/0/on/off.
RAG_ENABLED=true
